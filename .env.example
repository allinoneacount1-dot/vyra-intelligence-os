# ============================================================
# VYRA MULTI-CHAIN BLOCKCHAIN CONFIGURATION
# ============================================================
# ⚠️  NEVER COMMIT THIS FILE TO GIT
# ⚠️  Add .env to .gitignore
# ⚠️  Add these vars to Vercel Dashboard → Settings → Environment Variables
# ============================================================

# =========================
# ALCHEMY RPC ENDPOINTS
# =========================
ALCHEMY_ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_ETH_KEY
ALCHEMY_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_BASE_KEY
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY

# =========================
# SOLANA PROVIDER (HELIUS recommended)
# =========================
SOLANA_RPC=https://rpc.helius.xyz/?api-key=YOUR_HELIUS_KEY
# Alternative: Alchemy Solana
# SOLANA_RPC=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

HELIUS_API_KEY=YOUR_HELIUS_KEY

# =========================
# BNB CHAIN (optional — can use public RPC)
# =========================
BNB_RPC=https://bsc-dataseed.binance.org/
# Or via Alchemy: https://bnb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# =========================
# REDIS (Upstash serverless)
# =========================
UPSTASH_REDIS_URL=redis://YOUR_UPSTASH_HOST:6379
UPSTASH_REDIS_TOKEN=YOUR_UPSTASH_TOKEN
# Or use REST API (no persistent connection needed):
UPSTASH_REST_URL=https://YOUR_UPSTASH_URL
UPSTASH_REST_TOKEN=YOUR_UPSTASH_REST_TOKEN

# =========================
# INTERNAL SYSTEM
# =========================
EVENT_STREAM_PORT=4001
WEBSOCKET_PORT=4002
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================
# SECURITY
# =========================
# Secret for signing internal API calls between frontend and backend
VYRA_API_SECRET=CHANGE_ME_TO_RANDOM_STRING_32_CHARS
